# MatLink v2 — environment variables. Copy to `.env.local` and fill in.
# Supabase: Dashboard → Project Settings → API
# NEVER commit `.env.local`. Only this `.env.example` is tracked.

# Public Supabase API URL, e.g. https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Publishable (anon) key — safe for the browser; RLS enforces all access.
# Modern format: sb_publishable_...  (legacy anon JWT also works)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret (service-role) key — SERVER-ONLY. Bypasses RLS. Never expose to the client.
# Used by server-side admin actions and the seed script (later phases).
SUPABASE_SECRET_KEY=

# Resend API key — transactional email (verification approved/denied). Later phase.
RESEND_API_KEY=
